set_global_assignment -name VERILOG_FILE cam_init_top.v
# Switched back to camera_display_top for the camera->BNN->7-segment
# integration work (roi_binarize_28x28.v/seg7_decoder.v below). Leftover
# from the bnn_demo_top real-hardware validation run further down this
# file -- that demo is done and confirmed working, see CLAUDE.md.
set_global_assignment -name TOP_LEVEL_ENTITY camera_display_top

# bnn_core.v (binarized CNN). It is instantiated by camera_display_top.v
# for the live camera -> ROI -> BNN -> 7-segment pipeline, and remains in
# the file list so it can also be synthesized on its own for a resource
# usage check:
#   1. Temporarily change the TOP_LEVEL_ENTITY line above to bnn_core
#   2. Processing > Start > Start Analysis & Synthesis ONLY -- do NOT run a
#      full Compile. bnn_core's image_in port is 784 bits wide (28x28 test
#      image, meant to be driven by a testbench, not real pins); the Fitter
#      stage will fail trying to assign 784+ pins to a device that doesn't
#      have anywhere near that many I/O. Analysis & Synthesis alone doesn't
#      need pin assignment to succeed and will still produce the Resource
#      Usage Summary (LEs/registers/memory bits) -- same report already
#      used earlier this project to diagnose the LAB overflow.
#   3. Change TOP_LEVEL_ENTITY back to camera_display_top afterward. (Done
#      here -- confirmed real Analysis & Synthesis results after the
#      row-memory rewrite: 2,860 LE / ~28% of the 10,320 LE budget, down
#      from the first version's 5,776 LE. See CLAUDE.md.)
set_global_assignment -name VERILOG_FILE bnn_core.v

# bnn_demo_top.v (real-hardware validation demo for bnn_core.v, its own
# standalone top-level, separate from both camera_display_top and the
# bnn_core-as-TOP_LEVEL_ENTITY resource check above). Unlike bnn_core.v
# alone, this one has a normal small pin list (clk/rst_n/key1_n/led[3:0] --
# 7 pins total) so it CAN go through a full Compile and actually be
# programmed onto the board:
#   1. Temporarily change the TOP_LEVEL_ENTITY line above to bnn_demo_top
#   2. Processing > Start > Start Compilation (full compile this time --
#      Fitter will succeed, this module's port list is tiny)
#   3. Program the board. It auto-classifies test image 0 on power-up (LEDs
#      should show 0111 = 7 within well under a second, no button needed),
#      then KEY1 (the same physical button as key1_n/PIN_M15) advances
#      through 6 more real MNIST test images, wrapping back to image 0
#      after the last one. Expected LED sequence (binary, LED3..LED0 =
#      digit_out[3:0]): 7, 1, 0, 4, 9, 3, 6, back to 7 -- that "6" on the
#      7th image is not a bug, it's the same deliberate misclassification
#      (true label 2) that tb_bnn_core.v already exercises; seeing the
#      board reproduce that exact wrong answer (not some other value) is
#      actually the strongest confirmation that real silicon matches
#      simulation bit-for-bit, not just on the easy cases.
#   4. Change TOP_LEVEL_ENTITY back to camera_display_top afterward.
# clk/rst_n/key1_n/led all reuse the SAME global (non -entity-scoped) pin
# assignments already below (PIN_E1/PIN_N13/PIN_M15/PIN_E10,F9,C9,D9) --
# no new location/IO_STANDARD assignments needed for this module.
set_global_assignment -name VERILOG_FILE bnn_demo_top.v

